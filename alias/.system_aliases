# Aliases
# To load, put "source ~/.system_aliases" in your .bashrc, .zshrc, or config.fish
# Works (supposedly) with bash, zsh, and fish
if command -v exa &> /dev/null; then
    LS_EXE=exa
else
    LS_EXE=ls
fi
alias a="alias"
alias alg="alias | grep"
alias wh="which"
alias l="$LS_EXE"
alias la="$LS_EXE -a"
alias ll="$LS_EXE -lh"
alias llg="$LS_EXE -lh --git"
alias lt="$LS_EXE -lTh"
alias lla="$LS_EXE -lah"
alias lld="date; $LS_EXE -l"
alias lal="lla"
alias lah="ls -lah"
alias l.="ls -d .*"
alias lf="ls *(.)"
alias ld="ls *(/)"
alias lsh="ls .*"
alias lsd="ls -d *(/)"
alias lsy="ls | fzf"
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias .....="cd ../../../.."
alias ......="cd ../../../../.."
alias .......="cd ../../../../../.."
alias cd-="cd -"
alias cpr="cp -r"
alias rmrf="rm -rf"
alias rmd="rm -rf"
alias rmdd="rm -rf */"
alias mkdirp="mkdir -p"
alias pwdcp='pwd | sed "s|^$HOME||" | sed "s|^/||" | xclip -sel clip'
alias pwdcpp="pwd | xclip -sel clip"
alias mcm="make clean && make"
alias sus="sudo -sE"
